# ── Server ──────────────────────────────────────────────
LOCALBRAIN_HOST=127.0.0.1
LOCALBRAIN_PORT=8090
LOCALBRAIN_LOG_LEVEL=info
LOCALBRAIN_DEV_MODE=false

# ── Ingestion ──────────────────────────────────────────
LOCALBRAIN_ACCESS_CONFIG=access.config.json
LOCALBRAIN_PLUGINS_CONFIG=plugins.yaml
LOCALBRAIN_DATA_DIR=~/.localbrain
LOCALBRAIN_DEBOUNCE_MS=300
LOCALBRAIN_SETTLE_TIME_MS=5000
LOCALBRAIN_POLL_INTERVAL_S=60.0

# ── Router Handoff ─────────────────────────────────────
LOCALBRAIN_ROUTER_URL=http://localhost:8080
LOCALBRAIN_ROUTER_API_KEY=
LOCALBRAIN_BACKPRESSURE_MAX=10000

# ── Janitor ────────────────────────────────────────────
LOCALBRAIN_JANITOR_PURGE_DAYS=7
LOCALBRAIN_JANITOR_REINDEX_THRESHOLD=0.20
LOCALBRAIN_JANITOR_INTERVAL_S=300

# ── Security ───────────────────────────────────────────
LOCALBRAIN_API_KEY=
LOCALBRAIN_CORS_ORIGINS=*
LOCALBRAIN_RATE_LIMIT_RPM=120
LOCALBRAIN_MAX_BODY_SIZE=10485760
LOCALBRAIN_REQUEST_TIMEOUT=30.0
